{% extends "layouts.master" %}

{% block title %}Glossary - {{ glossary.name }} - Edit entry{% endblock %}

{% block content %}
<ol class="breadcrumb">
    <li><a href="{{ route('projects.index') }}">Home</a></li>
    <li><a href="{{ route('glossaries') }}">Glossaries</a></li>
    <li><a href="{{ route('glossaries.entries.index', {glossary: glossary.id}) }}">{{ glossary.name }}</a></li>
    <li>{{ entry.text }}</li>
    <li class="active">Edit</li>
</ol>

{% if errors.all() %}
<div class="alert alert-danger" role="alert">
    {% for error in errors.all() %}
    <p>{{ error }}</p>
    {% endfor %}
</div>
{% endif %}

<form action="{{ route('glossaries.entries.update', {glossary: glossary.id, entry: entry.id}) }}" method="post">
{{ method_field('PUT') }}
{{ csrf_field() }}
<div class="row form-group">
    <div class="col-md-6">
        <textarea name="text" id="text" class="form-control" placeholder="Text">{{ entry.text }}</textarea>
    </div>
    <div class="col-md-6">
        <textarea name="translation" id="translation" class="form-control" placeholder="Translation">{{ entry.translation }}</textarea>
    </div>
</div>
<div class="row form-group">
    <div class="col-md-12">
        <input type="submit" value="Save" class="btn btn-primary" style="width: 100%">
    </div>
</div>
</form>
{% endblock %}