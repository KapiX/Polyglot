{% extends "layouts.master" %}

{% block title %}Glossary - {{ glossary.name }} - Add entries{% endblock %}

{% block content %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb p-3 bg-body-secondary rounded">
        <li class="breadcrumb-item"><a href="{{ route('projects.index') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ route('glossaries') }}">Glossaries</a></li>
        <li class="breadcrumb-item"><a href="{{ route('glossaries.entries.index', [glossary]) }}">{{ glossary.name }}</a></li>
        <li class="breadcrumb-item active" aria-current="page">Add entries</li>
    </ol>
</nav>

{% if errors.all() %}
<div class="alert alert-danger" role="alert">
    {% for error in errors.all() %}
    <p>{{ error }}</p>
    {% endfor %}
</div>
{% endif %}

<form action="{{ route('glossaries.entries.store', [glossary]) }}" method="post">
{{ csrf_field() }}
<div class="row">
    <div class="col-md-12">
        <p class="alert alert-info">
            In the text areas below you can input texts with their translations to be added to the glossary.<br>
            Multiple entries can be added at once, each in their own line. Polyglot will match text in line 1 with translation in line 1, and so on.<br>
            If the batch contains already existing or duplicated entries it will be rejected as a whole.<br>
            Any entries where either text or translation is empty will be dropped, with the rest added normally.<br>
            Only full phrases should be added here, no partial matches.<br>
            Limit per batch: 500 entries.
        </p>
    </div>
</div>
<div class="row mb-3">
    <div class="col-md-6">
        <textarea name="text" id="text" class="form-control" placeholder="Texts">{{ old('text') }}</textarea>
    </div>
    <div class="col-md-6">
        <textarea name="translation" id="translation" class="form-control" placeholder="Translations">{{ old('translation') }}</textarea>
    </div>
</div>
<div class="row mb-3">
    <div class="col-md-12">
        <input type="submit" value="Add" class="btn btn-primary w-100">
    </div>
</div>
</form>
{% endblock %}