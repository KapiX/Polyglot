<!doctype html>
<html>
    <head>
        <meta charset="utf-8">
        <title>{% block title %}{% endblock %}</title>
        {% apply spaceless %}
        <link rel="icon" href="{{ asset('images/favicon16.png') }}" sizes="16x16">
        <link rel="icon" href="{{ asset('images/favicon24.png') }}" sizes="24x24">
        <link rel="icon" href="{{ asset('images/favicon32.png') }}" sizes="32x32">
        <link rel="icon" href="{{ asset('images/favicon48.png') }}" sizes="48x48">
        <link rel="icon" href="{{ asset('images/favicon64.png') }}" sizes="64x64">
        <link rel="icon" href="{{ asset('images/favicon96.png') }}" sizes="96x96">
        <link rel="icon" href="{{ asset('images/favicon128.png') }}" sizes="128x128">
        <link rel="shortcut icon" href="{{ asset('images/favicon128.png') }}">
        <link rel="apple-touch-icon" href="{{ asset('images/favicon128.png') }}">
        <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
        <link rel="stylesheet" href="{{ asset('css/bootstrap.dark.min.css') }}" media="(prefers-color-scheme: dark)">
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        <script src="{{ asset('js/jquery-3.2.1.min.js') }}"></script>
        <script src="{{ asset('js/bootstrap.min.js') }}"></script>
        {% endapply %}
        {% block scripts %}{% endblock %}
    </head>
    <body>
            <nav class="navbar navbar-default navbar-static-top">
                <div class="container">
                    <div class="navbar-header">
                        <a class="navbar-brand" href="{{ url('/') }}">
                            <picture>
                                <source srcset="{{ asset('images/Polyglot_dark_40px.png') }}" media="(prefers-color-scheme: dark)">
                                <img src="{{ asset('images/Polyglot_40px.png') }}">
                            </picture>
                        </a>
                    </div>
                    <div class="collapse navbar-collapse">
                        <ul class="nav navbar-nav">
                            {% if auth_user().can('global-settings') %}
                                <li><a href="{{ route('users.index') }}">Users</a></li>
                                <li><a href="{{ route('languages.index') }}">Languages</a></li>
                            {% endif %}
                            <li><a href="{{ route('glossaries') }}">Glossaries</a></li>
                            <li><a href="{{ route('help') }}">Help</a></li>
                        </ul>
                        <ul class="nav navbar-nav navbar-right">
                            {% if auth_check() %}
                                <li class="dropdown">
                                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">{{ auth_user().name }} <span class="caret"></span></a>
                                    <ul class="dropdown-menu">
                                        <li><a href="{{ route('profile') }}">Edit profile</a></li>
                                        <li role="separator" class="divider"></li>
                                        <li><a href="{{ route('auth.logout') }}">Logout</a></li>
                                    </ul>
                                </li>
                            {% else %}
                                <li><a href="{{ route('auth.provider', {provider: 'github'}) }}">Sign in with GitHub</a></li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </nav>
        <div class="container">
        {% if auth_check() and auth_user().languages is empty and auth_user().role == 0 %}
            <div class="alert alert-warning" role="alert">You don't have permissions to translate anything. They are required to do anything, until suggestions are implemented. See <a href="{{ route('help', {article: 'user'}) }}">Help for translators</a> for information.</div>
        {% endif %}
        {% block content %}{% endblock %}
        </div>
    </body>
</html>
