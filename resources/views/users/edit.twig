{% extends "layouts.master" %}
{% import "macros.forms" as forms %}

{% block title %}{{ user.name }} - Edit{% endblock %}

{% block content %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2 p-2 bg-body-secondary rounded">
        <li class="breadcrumb-item"><a href="{{ route('projects.index') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ route('users.index') }}">Users</a></li>
        <li class="breadcrumb-item">{{ user.name }}</li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
</nav>
<form action="{{ route('users.update', [user]) }}" method="post">
    {{ method_field('PUT') }}
    {{ csrf_field() }}
    <div class="row g-2">
        <div class="col col-lg-6 col-sm-12">
            <div class="mb-2">{{ forms.input('name', 'Name', user.name, errors) }}</div>
            <div class="mb-2">{{ forms.input('email', 'E-mail', user.email, errors) }}</div>
            <div class="mb-2">{{ forms.radiobox('role', 'Role', user.rolesNames(), user.role, 1, "list-group-horizontal", "flex-fill") }}</div>
        </div>
        <div class="col col-lg-6 col-sm-12 mh-100">
            {{ forms.checkboxes('languages', 'Language permissions',
                languages.mapWithKeys(l => {(l.id): "[#{l.iso_code}] #{l.name}"}),
                user.languages.pluck('id'), 2, "list-group-flush rounded", height="23em") }}
        </div>
        <div class="col"><input type="submit" value="Save" class="btn btn-primary w-100"></div>
    </div>
</form>
{% endblock %}
