{% extends "layouts.master" %}

{% block title %}Users{% endblock %}

{% block content %}
<ol class="breadcrumb">
    <li><a href="{{ route('projects.index') }}">Home</a></li>
    {% if not search %}
        <li class="active">Users</li>
    {% else %}
        <li><a href="{{ route('users.index') }}">Users</a></li>
        <li class="active">Search: {{ search }}</li>
    {% endif %}
</ol>

{% if session('success') %}
    <div class="alert alert-success" role="alert">{{ session('success') }}</div>
{% endif %}

<form action="{{ route('users.index') }}" method="get">
<div class="input-group">
    {% if search != '' %}
    <span class="input-group-btn">
        <a href="{{ route('users.index') }}" class="btn btn-default">&#x2715;</a>
    </span>
    {% endif %}
    <input type="text" name="search" id="search" value="{{ search }}" class="form-control" placeholder="Name or e-mail...">

    <span class="input-group-btn">
        <input type="submit" value="Search" class="btn btn-default">
    </span>
</div>
</form>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Name</th>
        <th>E-mail</th>
        <th>Role</th>
        <th>Language permissions</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    {% for user in users %}
    <tr>
        <td>{{ user.name }}</td>
        <td>{{ user.email }}</td>
        <td>{{ roles[user.role] }}</td>
        <td>
            {% for language in user.languages %}
            {{ language.iso_code }}{% if loop.last == false %}, {% endif %}
            {% endfor %}
        </td>
        <td>
            <a href="{{ route('users.edit', user.id) }}" class="btn btn-default {{ user.id == auth_user().id ? 'disabled' }}">Edit</a>
        </td>
    </tr>
    {% else %}
    <tr>
        <td colspan="4"><em>No users to show.</em></td>
    </tr>
    {% endfor %}
    </tbody>
</table>
{{ users.appends({'search': search}).links() | raw }}
{% endblock %}
