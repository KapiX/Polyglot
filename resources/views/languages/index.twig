{% extends "layouts.master" %}

{% block title %}Languages{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="mt-3">
    <ol class="breadcrumb p-3 bg-body-secondary rounded">
        <li class="breadcrumb-item"><a href="{{ route('projects.index') }}">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Languages</li>
    </ol>
</nav>

{% if session('message') %}
<div class="alert alert-success">{{ session('message') }}</div>
{% endif %}
<div class="row">
    {% for chunk in languages.chunk(((languages.count()) / 3)|round(0, 'ceil')) %}
    <div class="col"><div class="list-group mb-3">
    {% for language in chunk %}
        {% if language.name == "_Add" %}
        <a href="{{ route('languages.create') }}" class="list-group-item list-group-item-action">
            <h5 class="d-flex justify-content-center mt-1">+</h5>
            <div class="d-flex justify-content-between align-items-start position-relative">
                <button class="btn btn-sm invisible">#</button>
                <h6 class="position-absolute start-50 translate-middle-x">Add</h6>
            </div>
        </a>
        {% else %}
        <div class="list-group-item">
            <div class="d-flex w-100 justify-content-between align-items-start">
                <h5>{{ language.iso_code }}</h5>
                <h6>{{ language.name }}</h6>
            </div>
            <div class="d-flex w-100 justify-content-between align-items-start mb-1">
                <div>
                    <a href="{{ language.style_guide_url }}" class="btn btn-sm btn-outline-secondary {{ language.style_guide_url ?: 'disabled' }}">Style guide</a>
                    <a href="{{ language.terminology_url }}" class="btn btn-sm btn-outline-secondary {{ language.terminology_url ?: 'disabled' }}">Terminology</a>
                </div>
                <div>
                    <div class="btn-group">
                        <a href="{{ route('languages.edit', language.id) }}" class="btn btn-sm btn-primary">Edit</a>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    {% endfor %}
    </div></div>
    {% endfor %}
</div>
{% endblock %}
